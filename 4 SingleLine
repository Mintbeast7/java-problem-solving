class SingleLine {
    public static void main(String[] args) {
        //Right Half Pyramid
        System.out.println("*\n* *\n* * *\n* * * *\n* * * * *");
        //Reverse Right Half Pyramid
        System.out.println("* * * * *\n* * * *\n* * *\n* *\n*");
        //Left Half Pyramid
        System.out.println("        *\n      * *\n    * * *\n  * * * *\n* * * * *");
    }
}
